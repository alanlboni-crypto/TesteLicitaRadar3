# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Resend (e-mail) ──────────────────────────────────────────────────────────
# Crie em: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Remetente do e-mail ──────────────────────────────────────────────────────
# Para testes: use "onboarding@resend.dev" (só envia para o dono da conta Resend)
# Para produção: use um domínio verificado. Ex: "LicitaRadar <alerta@seudominio.com.br>"
FROM_EMAIL=LicitaRadar <onboarding@resend.dev>

# ─── URL do app (aparece no botão do e-mail) ──────────────────────────────────
APP_URL=https://seu-app.vercel.app

# ─── Segredo do Cron (gerado por você — qualquer string longa e aleatória) ────
# O Vercel envia esse valor no header Authorization ao chamar o cron job
CRON_SECRET=coloque-aqui-uma-string-secreta-longa
